{
    "name": "@devcycle/test-harness",
    "engines": {
        "node": ">=22.0.0"
    },
    "scripts": {
        "test": "jest --verbose",
        "test:ci": "BUILDKIT_PROGRESS=plain yarn test --setupFiles=./ci-config.ts --reporters=default --reporters=jest-junit",
        "test:unit": "jest --config=jest.unit.config.ts",
        "start:nodejs": "cd proxies/nodejs && NODE_PRESERVE_SYMLINKS=1 ts-node app.ts",
        "start:of-nodejs": "cd proxies/openfeature-nodejs && NODE_PRESERVE_SYMLINKS=1 ts-node app.ts",
        "start:go": "cd proxies/go && go run .",
        "start:dotnet": "cd proxies/dotnet && dotnet run",
        "start:java": "cd proxies/java && ./gradlew bootRun",
        "start:ruby": "cd proxies/ruby && bundle exec ruby app.rb",
        "start:python": "cd proxies/python && python3 -m flask --app app run --host=0.0.0.0 -p 3000",
        "use-local": "scripts/use-local.sh"
    },
    "version": "1.0.0",
    "description": "A universal testing system for DevCycle SDKs",
    "main": "index.js",
    "repository": "git@github.com:DevCycleHQ/test-harness.git",
    "author": "DevCycle <engineering@devcycle.com>",
    "license": "MIT",
    "devDependencies": {
        "@devcycle/types": "^1.30.2",
        "@eresearchqut/jest-testcontainers": "^3.8.0",
        "@koa/bodyparser": "^5.1.1",
        "@koa/router": "^13.0.1",
        "@types/jest": "^29.5.14",
        "@typescript-eslint/eslint-plugin": "^5.62.0",
        "@typescript-eslint/parser": "^5.62.0",
        "axios": "1.15.0",
        "eslint": "^8.57.1",
        "eslint-config-prettier": "^9.1.0",
        "eslint-plugin-prettier": "^5.2.4",
        "husky": "^8.0.3",
        "jest": "^29.7.0",
        "jest-extended": "^3.2.4",
        "jest-junit": "^15.0.0",
        "jest-serial-runner": "^1.2.1",
        "koa": "^3.1.2",
        "lint-staged": "^15.5.0",
        "nock": "^13.5.6",
        "prettier": "^3.5.3",
        "prettier-eslint": "^16.3.0",
        "prettier-eslint-cli": "^8.0.1",
        "ts-jest": "^29.3.0",
        "ts-node": "^10.9.2",
        "typescript": "^5.8.3"
    },
    "dependencies": {
        "dotenv": "^16.4.7",
        "object-path-immutable": "^4.1.2",
        "uuid": "^14.0.0"
    },
    "lint-staged": {
        "*.{ts,js}": [
            "eslint --fix"
        ]
    },
    "jest-junit": {
        "outputDirectory": ".",
        "outputName": "jest-junit.xml",
        "ancestorSeparator": " › ",
        "uniqueOutputName": "false",
        "suiteNameTemplate": "{filepath}",
        "classNameTemplate": "{classname}",
        "titleTemplate": "{title}"
    },
    "packageManager": "yarn@4.9.2",
    "resolutions": {
        "tar@^7.4.3": "^7.5.10",
        "minimatch@^3.0.4": "^3.1.3",
        "minimatch@^3.0.5": "^3.1.3",
        "minimatch@^3.1.1": "^3.1.3",
        "minimatch@^3.1.2": "^3.1.3",
        "minimatch@^5.0.1": "^5.1.8",
        "minimatch@^5.1.0": "^5.1.8",
        "minimatch@9.0.3": "^9.0.7",
        "brace-expansion@^1.1.7": "^1.1.13",
        "brace-expansion@^2.0.1": "^2.0.3",
        "brace-expansion@^2.0.2": "^2.0.3",
        "picomatch@^2.0.4": "^2.3.2",
        "picomatch@^2.2.3": "^2.3.2",
        "picomatch@^2.3.1": "^2.3.2",
        "picomatch@^4.0.2": "^4.0.4",
        "flatted@^3.2.9": "^3.4.2",
        "undici@^7.10.0": "^7.24.6",
        "lodash@^4.17.15": "^4.18.0",
        "lodash@^4.17.21": "^4.18.0",
        "protobufjs@^7.2.5": "^7.5.5",
        "protobufjs@^7.3.2": "^7.5.5",
        "follow-redirects@^1.15.11": "^1.16.0",
        "uuid": "^14.0.0"
    }
}
